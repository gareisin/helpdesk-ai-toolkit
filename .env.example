# Copy to .env and adjust, or just export these in your shell.
# This single variable is the hybrid-architecture swap point.

# mock | ollama | anthropic
LLM_PROVIDER=mock

# --- ollama (local open-source model; the cheap runtime tier) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- anthropic (frontier model; the architect tier) ---
ANTHROPIC_MODEL=claude-opus-4-8
# ANTHROPIC_API_KEY is read from the environment by the SDK — do not put it in files.
